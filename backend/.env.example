# ---- Backend environment configuration ----
# Copy this file to ".env" and fill in real values. Never commit ".env".

# Database connection string.
# SQLite (default, file-based): sqlite:///./portfolio.db
# Postgres example:            postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./portfolio.db

# Alpha Vantage API key for live market data.
# Get a free key at https://www.alphavantage.co/support/#api-key
# Leave blank to run on cached/mock data only.
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# JWT signing secret. REQUIRED in production.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed frontend origins for CORS.
# Dev: *   |   Prod example: https://your-frontend-domain.com
CORS_ORIGINS=*
